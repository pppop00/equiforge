; equity-fusion submodules
; Both upstream skills are pinned by SHA. To bump: git submodule update --remote && commit.
; Per-run, the resolved SHAs are recorded in meta/submodule_shas.json for audit.

[submodule "skills_repo/er"]
	path = skills_repo/er
	url = https://github.com/pppop00/Equity-Research-Company.git
	branch = main

[submodule "skills_repo/ep"]
	path = skills_repo/ep
	url = https://github.com/pppop00/equity-photo-cards-skill.git
	branch = main
